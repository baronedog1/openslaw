# Core ports and database
DB_NAME=openslaw
DB_USER=openslaw
DB_PASSWORD=change-this-in-production
DB_PORT=51012

API_PORT=51011
FRONTEND_PORT=51010

# Public origins
CORS_ORIGIN=http://127.0.0.1:51010
PUBLIC_WEB_BASE_URL=http://127.0.0.1:51010
PUBLIC_API_BASE_URL=http://127.0.0.1:51011/api/v1

# Credits and tokens
SIGNUP_GRANT_AMOUNT=100
OWNER_LINK_MASTER_KEY=replace-with-a-long-random-secret
CALLBACK_MASTER_KEY=replace-with-a-long-random-secret
SYSTEM_CRON_TOKEN=replace-with-a-long-random-token

# Mail delivery
EMAIL_DELIVERY_MODE=console
EMAIL_FROM=OpenSlaw <noreply@example.com>
EMAIL_EXPOSE_DEBUG_SECRETS=false
OWNER_CLAIM_TTL_HOURS=168
OWNER_LOGIN_LINK_TTL_MINUTES=30
OWNER_SESSION_TTL_HOURS=168
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=OpenSlaw

# Uploads and object storage
PLATFORM_MANAGED_DELIVERY_ENABLED=false
PLATFORM_MANAGED_ARTIFACT_MAX_BYTES=31457280
PLATFORM_MANAGED_ARTIFACT_TOTAL_BYTES_PER_ORDER_SIDE=31457280
PLATFORM_MANAGED_ARTIFACT_MEMBER_MAX_BYTES=1073741824
PLATFORM_MANAGED_ARTIFACT_MEMBER_TOTAL_BYTES_PER_ORDER_SIDE=1073741824
PLATFORM_MANAGED_DOWNLOAD_MAX_CONCURRENT=15
PLATFORM_MANAGED_DOWNLOAD_MAX_CONCURRENT_PER_AGENT=4
PLATFORM_MANAGED_DOWNLOAD_MAX_CONCURRENT_PER_IP=6
PLATFORM_MANAGED_DOWNLOAD_RATE_LIMIT_PER_IP=40
PLATFORM_MANAGED_DOWNLOAD_RATE_LIMIT_WINDOW_SECONDS=60
PLATFORM_MANAGED_LARGE_ARTIFACT_PENDING_RETENTION_HOURS=48
PLATFORM_MANAGED_LARGE_ARTIFACT_TERMINAL_RETENTION_DAYS=7
PLATFORM_MANAGED_STALE_UPLOADING_TTL_HOURS=24
PLATFORM_MANAGED_STALE_UPLOADED_TTL_HOURS=168
PLATFORM_MANAGED_COMPLETED_RETENTION_DAYS=90
PLATFORM_MANAGED_DISPUTED_RETENTION_DAYS=180
PLATFORM_MANAGED_CLEANUP_BATCH_LIMIT=100
OSS_SIGNED_UPLOAD_EXPIRES_SECONDS=900
OSS_OPENSLAW_DELIVERY_PREFIX=ai/openslaw/orders
OSS_ENDPOINT=
OSS_INTERNAL_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# Rate limits
REGISTER_RATE_LIMIT_PER_IP=3
REGISTER_RATE_LIMIT_WINDOW_SECONDS=60
REGISTER_EMAIL_COOLDOWN_SECONDS=60
OWNER_CLAIM_EMAIL_COOLDOWN_SECONDS=60
OWNER_LOGIN_RATE_LIMIT_PER_IP=6
OWNER_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
OWNER_LOGIN_EMAIL_COOLDOWN_SECONDS=60
OWNER_CLAIM_RATE_LIMIT_PER_IP=10
OWNER_CLAIM_RATE_LIMIT_WINDOW_SECONDS=60

# Runtime relay
RUNTIME_RELAY_LEASE_HOURS=48
RUNTIME_RELAY_PREMIUM_LEASE_HOURS=480
RUNTIME_RELAY_AUTH_TIMEOUT_SECONDS=10
RUNTIME_RELAY_SWEEP_INTERVAL_SECONDS=60
RUNTIME_RELAY_PENDING_REPLAY_BATCH_SIZE=100
RUNTIME_RELAY_MAX_CONNECTIONS=1000
